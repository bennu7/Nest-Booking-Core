# Salin ke .env.test: cp .env.test.example .env.test
# Atau salin dari .env lalu sesuaikan DATABASE_URL ke database PostgreSQL *khusus test*
# (nama DB berbeda dari dev, contoh: .../nest_booking_test).

DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/nest_booking_test
PORT=3001
NODE_ENV=test

JWT_SECRET=e2e-jwt-secret-min-32-chars-for-tests-only
JWT_EXPIRES_IN=15m
JWT_SECRET_REFRESH=e2e-refresh-secret-min-32-chars-tests
JWT_SECRET_REFRESH_EXPIRES_IN=7

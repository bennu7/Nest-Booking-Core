// ============================================
// Model: User
// Deskripsi: Semua User (Customer, Provider, Admin)
// ============================================

model User {
  id             String       @id @default(uuid())
  tenantId       String?      @map("tenant_id")
  email          String       @db.VarChar(255)
  passwordHash   String?      @map("password_hash") @db.VarChar(255)
  fullName       String       @map("full_name") @db.VarChar(255)
  phone          String?      @db.VarChar(20)
  avatarUrl      String?      @map("avatar_url") @db.Text
  role           UserRole     @default(CUSTOMER)
  authProvider   AuthProvider @default(LOCAL) @map("auth_provider")
  authProviderId String?      @map("auth_provider_id") @db.VarChar(255)
  isActive       Boolean      @default(true) @map("is_active")
  disabledReason String?      @map("disabled_reason") @db.VarChar(500)
  disabledAt     DateTime?    @map("disabled_at")
  disabledBy     String?      @map("disabled_by")
  lastLoginAt    DateTime?    @map("last_login_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relations
  tenant            Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  disabledByUser    User?            @relation("DisabledByUser", fields: [disabledBy], references: [id])
  usersDisabled     User[]           @relation("DisabledByUser")
  refreshTokens     RefreshToken[]
  providerProfile   ProviderProfile?
  bookings          Booking[]
  notifications     Notification[]
  slotHolds         SlotHold[]
  cancelledBookings Booking[]        @relation("CancelledBookings")
  idempotencyKeys   IdempotencyKey[]

  @@unique([tenantId, email])
  @@unique([email])
  @@index([tenantId])
  @@index([tenantId, email])
  @@map("users")
}

// ============================================
// Model: Payment
// Deskripsi: Tracking Pembayaran (Phase 2b)
// ============================================

model Payment {
  id                String        @id @default(uuid())
  tenantId          String        @map("tenant_id")
  bookingId         String        @unique @map("booking_id")
  amount            Decimal       @map("amount") @db.Decimal(12, 2)
  currency          String        @default("IDR") @map("currency") @db.VarChar(3)
  status            PaymentStatus @default(PENDING) @map("status")
  paymentMethod     String?       @map("payment_method")
  externalPaymentId String?       @unique @map("external_payment_id") @db.VarChar(255)
  paidAt            DateTime?     @map("paid_at")
  refundedAt        DateTime?     @map("refunded_at")
  metadata          Json          @default("{}") @map("metadata")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // Relations
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bookingId])
  @@index([externalPaymentId])
  @@map("payments")
}
